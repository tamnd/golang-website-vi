{{define "pkg path name?" -}}
<a href="https://pkg.go.dev/{{.path}}?tab=overview">{{or .name .path}}</a>
{{- end}}


{{define "breadcrumb"}}
{{$elems := strings.Split (strings.Trim . "/") "/"}}
{{$prefix := slice $elems 0 (sub (len $elems) 1)}}
{{range $i, $elem := $prefix -}}
<a href="/{{strings.Join (slice $prefix 0 (add $i 1)) "/"}}/">{{$elem}}</a>/
{{- end -}}
<span class="text-muted">{{strings.Join (slice $elems (len $prefix) (len $elems)) "/"}}</span>
{{end}}

{{define "doclayout"}}
{{/* used from various subdirectory default.tmpl */}}
<article class="Doc Article">
{{if .sidebar }}
<div class="Article-columns">
<div class="Article-content">
{{end}}

{{if .breadcrumb}}
  {{ breadcrumbs . }}
{{end}}

{{if .title}}
<h1>{{if strings.HasPrefix .URL "/wiki/"}}Go Wiki: {{end}}{{.title}}</h1>
{{else if eq .layout "error"}}
<h1>Lỗi</h1>
{{else if eq .layout "dir"}}
<h1>Thư mục {{breadcrumb .URL}}</h1>
{{else if and (eq .layout "texthtml") (strings.HasSuffix .URL ".go")}}
<h1>Tệp nguồn {{breadcrumb .URL}}</h1>
{{else if eq .layout "texthtml"}}
<h1>Tệp văn bản {{breadcrumb .URL}}</h1>
{{end}}

{{with .subtitle}}
<h2 class="subtitle">{{.}}</h2>
{{end}}

{{/* The Table of Contents is automatically inserted in this <div>.
     Do not delete this <div>. */}}
{{if not .hidetoc}}
<div id="nav" class="TOC"></div>
{{end}}


{{.Content}}

{{if .sidebar }}
</div>
{{if eq .sidebar "faq"}}
{{ faqsidebar .}}
{{else if eq .sidebar "bug"}}
{{ bugsidebar .}}
{{end}}
</div>
{{end}}

{{if strings.HasPrefix .URL "/wiki/"}}
<hr>
<p>
<i>Nội dung này là một phần của <a href="/wiki/">Go Wiki</a>.</i>
</p>
{{end}}
{{if strings.HasPrefix .URL "/gopls/"}}
<hr>
<p>
<i>Tệp nguồn cho tài liệu này nằm tại <a href="https://cs.opensource.google/go/x/tools/+/master:gopls/doc/">golang.org/x/tools/gopls/doc</a>.</i>
</p>
{{end}}

</article>

{{end}}

{{define "bugsidebar"}}
<aside class="Sidebar">
  <h4>Báo cáo sự cố</h4>
  <p>Nếu bạn phát hiện lỗi, sai sót hoặc mâu thuẫn trong mã nguồn hay tài liệu của dự án Go, vui lòng thông báo cho chúng tôi bằng cách gửi ticket trên <a href="https://github.com/golang/go/issues">trình theo dõi sự cố.</a> Tất nhiên, bạn nên kiểm tra xem sự cố đã tồn tại chưa trước khi tạo mới.</p>
  <a class="btn" href="https://github.com/golang/go/issues" aria-describedby="footer-description">Gửi ticket</a>
</aside>
{{end}}

{{define "faqsidebar"}}
<aside class="Sidebar Sidebar-faq">
  <h4>Ghi chú bản phát hành</h4>
  <p>Tìm hiểu những điểm mới trong mỗi bản phát hành Go.</p>
  <a class="link" href="/doc/devel/release" aria-describedby="footer-description">Xem ghi chú bản phát hành</a>

  <h4>Quy tắc ứng xử</h4>
  <p>Hướng dẫn tham gia các không gian cộng đồng Go và quy trình xử lý sự cố.</p>
  <a class="link" href="/conduct" aria-describedby="footer-description">Xem thêm</a>

  <h4>Hướng dẫn thương hiệu</h4>
  <p>Hướng dẫn về việc sử dụng lại logo Go, linh vật gopher và các tài nguyên khác.</p>
  <a class="link" href="/blog/go-brand" aria-describedby="footer-description">Xem hướng dẫn</a>

  <h4>Hướng dẫn đóng góp</h4>
  <p>Tìm hiểu cách báo cáo lỗi, gửi pull request hoặc đóng góp cho hệ sinh thái Go.</p>
  <a class="link" href="/doc/contribute" aria-describedby="footer-description">Xem hướng dẫn</a>

  <h4>Kết nối</h4>
  <div class="Sidebar-socialLinks">
    <a href="https://bsky.app/profile/golang.org" rel="noopener noreferrer" target="_blank">
      <img width="16" height="16" src="/images/logos/social/bluesky.svg" aria-hidden="true" />
    </a>
    <a href="https://hachyderm.io/@golang" rel="noopener noreferrer" target="_blank">
      <img width="16" height="16" src="/images/logos/social/mastodon.svg" aria-hidden="true" />
    </a>
    <a href="https://twitter.com/golang" rel="noopener noreferrer" target="_blank">
      <img width="15" height="12" src="/images/icons/twitter.svg" aria-hidden="true" />
    </a>
    <a href="https://www.reddit.com/r/golang/" rel="noopener noreferrer" target="_blank">
      <img width="16" height="16" src="/images/icons/reddit.svg" aria-hidden="true" />
    </a>
    <a href="https://github.com/golang" rel="noopener noreferrer" target="_blank">
      <img width="16" height="16" src="/images/icons/github.svg" aria-hidden="true" />
    </a>
    <a href="https://gophers.slack.com/" rel="noopener noreferrer" target="_blank">
      <img width="16" height="16" src="/images/icons/slack.svg" aria-hidden="true" />
    </a>
  </div>
</aside>
{{end}}
