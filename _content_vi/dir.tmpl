{{define "layout"}}

<article class="Dir Article">

<h1>Thư mục {{breadcrumb .URL}}</h1>

<p>
<table class="layout">
<tr>
	<th align="left">Tệp</th>
	<td width="25">&nbsp;</td>
	<th align="right">Byte</th>
</tr>
<tr>
	<td><a href="../">../</a><td><td>
</tr>

{{range .dir}}{{if .IsDir}}
	<tr><td align="left"><a href="{{.Name}}/">{{.Name}}/</a><td><td></tr>
{{end}}{{end}}
{{range .dir}}{{if not .IsDir}}
	<tr><td align="left"><a href="{{.Name}}">{{.Name}}</a><td><td align="right">{{.Size}}</tr>
{{end}}{{end}}

</table>
</p>

</article>

{{end}}
