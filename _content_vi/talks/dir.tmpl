{{define "layout"}}

<article class="Talks Article">

{{with .dir}}
  <h1>Go talks</h1>

  {{with .Path}}<h2>{{.}}</h2>{{end}}

  {{with .Articles}}
  <h4>Bài viết:</h4>
  <dl>
  {{range .}}
  <dd><a href="/{{.Path}}" aria-describedby="talks-description">{{.Name}}</a>: {{.Title}}</dd>
  {{end}}
  </dl>
  {{end}}

  {{with .Slides}}
  <h4>Bộ slide:</h4>
  <dl>
  {{range .}}
  <dd><a href="/{{.Path}}" aria-describedby="talks-description">{{.Name}}</a>: {{.Title}}</dd>
  {{end}}
  </dl>
  {{end}}

  {{with .Other}}
  <h4>Tệp:</h4>
  <dl>
  {{range .}}
  <dd><a href="/{{.Path}}" aria-describedby="talks-description">{{.Name}}</a></dd>
  {{end}}
  </dl>
  {{end}}

  {{with .Dirs}}
  <h4>Thư mục con:</h4>
  <dl>
  {{range .}}
  <dd><a href="/{{.Path}}" aria-describedby="talks-description">{{.Name}}</a></dd>
  {{end}}
  </dl>
  {{end}}
{{end}}

</article>

<div class="screen-reader-only" id="talks-description" hidden>
          Mở trong cửa sổ mới.
    </div>
{{end}}
